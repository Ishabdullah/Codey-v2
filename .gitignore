# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.env
.venv
venv/
env/

# ── Codey-v2: user-generated / per-install files ──────────────────────────────
# Users generate these themselves after install — should NOT be in the repo
CODEY.md
CLAUDE.md

# ── Codey-v2: runtime state ───────────────────────────────────────────────────
# Daemon state, logs, PID, socket, checkpoints, sessions
~/.codey-v2/
.codey-v2/
*.pid
*.sock
*.log
codey_sessions/
.codey_sessions/
checkpoints/

# ── Codey-v2: knowledge base (auto-generated, per-install) ───────────────────
# 266MB of external content (cloned repos, chunk indexes, vector stores).
# Generated locally — never commit.
knowledge/

# ── Codey-v2: model files ─────────────────────────────────────────────────────
# Models live in ~/models/, never committed
*.gguf
*.bin
*.safetensors
model/

# ── Codey-v2: fine-tuning output ──────────────────────────────────────────────
*.jsonl
*.ipynb
codey-finetune*/
codey-lora*/

# ── Codey-v2: dev artifacts ───────────────────────────────────────────────────
backups/
codey_backup_*/
backups/
.pytest_cache/
.codeyignore
audit_report_*.md
REFACTOR_*.md
RELEASE_NOTES_*.md
test_checkpoint.json
test1_output.log
test_project/

# ── Secrets ───────────────────────────────────────────────────────────────────
*.key
*.pem
*.token
secrets.py
config.local.*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
