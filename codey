#!/usr/bin/env bash
#
# codey - Codey CLI Client
#
# If daemon is running, connects via Unix socket.
# Otherwise, spawns direct mode.
#

CODEY_DIR="${CODEY_DIR:-$HOME/codey}"
DAEMON_DIR="$HOME/.codey"
PID_FILE="$DAEMON_DIR/codey.pid"
SOCKET_FILE="$DAEMON_DIR/codey.sock"

# Get the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check if daemon is running
is_daemon_running() {
    if [ ! -f "$PID_FILE" ]; then
        return 1
    fi
    
    PID=$(cat "$PID_FILE" 2>/dev/null || echo "")
    if [ -z "$PID" ]; then
        return 1
    fi
    
    # Check if process exists
    if ! kill -0 "$PID" 2>/dev/null; then
        return 1
    fi
    
    # Check if socket exists and is connectable
    if [ -f "$SOCKET_FILE" ]; then
        return 0
    fi
    
    return 1
}

# Send command to daemon via socket
send_to_daemon() {
    local prompt="$1"
    local yolo="$2"
    
    TMPSCRIPT="$(mktemp "$DAEMON_DIR/socket_XXXX.py")"
    
    cat > "$TMPSCRIPT" << PYEOF
import sys
import json
import socket

SOCKET_FILE = "$SOCKET_FILE"

def send_command(cmd, data):
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    sock.settimeout(30.0)
    
    try:
        sock.connect(str(SOCKET_FILE))
        request = {"cmd": cmd, "data": data}
        sock.sendall(json.dumps(request).encode('utf-8'))
        
        response_data = b""
        while True:
            chunk = sock.recv(65536)
            if not chunk:
                break
            response_data += chunk
        
        return json.loads(response_data.decode('utf-8'))
    finally:
        sock.close()

# Send the prompt to daemon
result = send_command("command", {"prompt": """$prompt""", "yolo": $yolo})
print(json.dumps(result, indent=2))
PYEOF
    
    python3 "$TMPSCRIPT"
    rm -f "$TMPSCRIPT"
}

# Check for daemon-specific commands
if [ "$1" = "--daemon" ]; then
    # Pass through to main.py with daemon flag
    TMPSCRIPT="$(mktemp /data/data/com.termux/files/usr/tmp/codey_run_XXXX.py)"
    
    cat > "$TMPSCRIPT" << PYEOF
import sys
sys.path.insert(0, '$SCRIPT_DIR')
from main import main
main()
PYEOF
    
    python3 "$TMPSCRIPT" "\$@"
    rm -f "$TMPSCRIPT"
    exit $?
fi

# Check if daemon is running
if is_daemon_running; then
    # Daemon mode: send command via socket
    if [ $# -gt 0 ]; then
        # Has arguments, send as prompt
        YOLO="False"
        for arg in "\$@"; do
            if [ "$arg" = "--yolo" ]; then
                YOLO="True"
            fi
        done
        
        PROMPT="\$*"
        send_to_daemon "$PROMPT" "$YOLO"
    else
        # No arguments, show status
        echo "Codey daemon is running"
        echo "Use 'codeyd status' for details"
        echo "Type your prompt or use --chat for interactive mode"
    fi
else
    # Direct mode: spawn Python directly
    TMPSCRIPT="$(mktemp /data/data/com.termux/files/usr/tmp/codey_run_XXXX.py)"
    
    cat > "$TMPSCRIPT" << PYEOF
import sys
sys.path.insert(0, '$SCRIPT_DIR')
from main import main
main()
PYEOF
    
    python3 "$TMPSCRIPT" "\$@"
    rm -f "$TMPSCRIPT"
fi
