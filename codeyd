#!/usr/bin/env bash
#
# codeyd - Codey v2 Daemon Manager
#
# Commands:
#   start   - Start the daemon in background
#   stop    - Stop the running daemon
#   status  - Show daemon status
#   restart - Restart the daemon
#   reload  - Send reload signal (SIGUSR1)
#

set -e

CODEY_DIR="${CODEY_DIR:-$HOME/codey}"
DAEMON_DIR="$HOME/.codey"
PID_FILE="$DAEMON_DIR/codey.pid"
LOG_FILE="$DAEMON_DIR/codey.log"

# Ensure daemon directory exists
mkdir -p "$DAEMON_DIR"

# Get the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

show_status() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE" 2>/dev/null || echo "")
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            echo "Codey daemon is running (PID: $PID)"
            
            # Show basic stats
            if [ -f "$DAEMON_DIR/state.db" ]; then
                echo "State database: $DAEMON_DIR/state.db"
            fi
            
            return 0
        else
            echo "Codey daemon is not running (stale PID file)"
            rm -f "$PID_FILE"
            return 1
        fi
    else
        echo "Codey daemon is not running"
        return 1
    fi
}

start_daemon() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE" 2>/dev/null || echo "")
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            echo "Daemon is already running (PID: $PID)"
            return 0
        else
            echo "Removing stale PID file"
            rm -f "$PID_FILE"
        fi
    fi
    
    echo "Starting Codey daemon..."
    
    # Create launcher script
    TMPSCRIPT="$(mktemp "$DAEMON_DIR/daemon_run_XXXX.py")"
    
    cat > "$TMPSCRIPT" << PYEOF
import sys
import os

# Set up paths
CODEY_DIR = "$SCRIPT_DIR"
sys.path.insert(0, CODEY_DIR)

# Set environment
os.environ.setdefault("CODEY_DIR", "$CODEY_DIR")

# Import and run daemon
from core.daemon import main
main()
PYEOF
    
    # Start daemon in background, redirect output to log
    nohup python3 "$TMPSCRIPT" > "$LOG_FILE" 2>&1 &
    DAEMON_PID=$!
    
    # Wait briefly and check if it started
    sleep 1
    
    if kill -0 "$DAEMON_PID" 2>/dev/null; then
        echo "Daemon started (PID: $DAEMON_PID)"
        echo "Log file: $LOG_FILE"
    else
        echo "Failed to start daemon. Check log: $LOG_FILE"
        rm -f "$TMPSCRIPT"
        return 1
    fi
    
    # Cleanup temp script after a delay (daemon copies what it needs)
    (sleep 5 && rm -f "$TMPSCRIPT") &
}

stop_daemon() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Daemon is not running"
        return 1
    fi
    
    PID=$(cat "$PID_FILE" 2>/dev/null || echo "")
    
    if [ -z "$PID" ] || ! kill -0 "$PID" 2>/dev/null; then
        echo "Daemon is not running (stale PID file)"
        rm -f "$PID_FILE"
        return 1
    fi
    
    echo "Stopping Codey daemon (PID: $PID)..."
    
    # Send SIGTERM for graceful shutdown
    kill -TERM "$PID" 2>/dev/null || true
    
    # Wait for process to exit
    for i in {1..10}; do
        if ! kill -0 "$PID" 2>/dev/null; then
            echo "Daemon stopped"
            rm -f "$PID_FILE"
            return 0
        fi
        sleep 0.5
    done
    
    # Force kill if still running
    echo "Force killing daemon..."
    kill -9 "$PID" 2>/dev/null || true
    rm -f "$PID_FILE"
    echo "Daemon stopped (forced)"
}

restart_daemon() {
    stop_daemon || true
    sleep 1
    start_daemon
}

reload_daemon() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Daemon is not running"
        return 1
    fi
    
    PID=$(cat "$PID_FILE" 2>/dev/null || echo "")
    
    if [ -z "$PID" ] || ! kill -0 "$PID" 2>/dev/null; then
        echo "Daemon is not running"
        rm -f "$PID_FILE"
        return 1
    fi
    
    echo "Sending reload signal to daemon (PID: $PID)..."
    kill -USR1 "$PID"
    echo "Reload signal sent"
}

# Main command dispatcher
case "${1:-status}" in
    start)
        start_daemon
        ;;
    stop)
        stop_daemon
        ;;
    status)
        show_status
        ;;
    restart)
        restart_daemon
        ;;
    reload)
        reload_daemon
        ;;
    *)
        echo "Usage: codeyd {start|stop|status|restart|reload}"
        echo ""
        echo "Commands:"
        echo "  start   - Start the daemon in background"
        echo "  stop    - Stop the running daemon"
        echo "  status  - Show daemon status"
        echo "  restart - Restart the daemon"
        echo "  reload  - Send reload signal (SIGUSR1)"
        exit 1
        ;;
esac
